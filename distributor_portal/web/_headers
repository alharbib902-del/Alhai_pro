# Cloudflare Pages security headers for Alhai Distributor Portal
# Applies to all paths. Canonical source of truth; nginx.conf and vercel.json
# are kept in sync for non-Cloudflare deployment targets.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://www.gstatic.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.sentry.io https://*.ingest.sentry.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; report-uri https://__SENTRY_CSP_REPORT_URI__/; report-to csp-endpoint
  Report-To: {"group":"csp-endpoint","max_age":86400,"endpoints":[{"url":"https://__SENTRY_CSP_REPORT_URI__/"}],"include_subdomains":true}
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-XSS-Protection: 0
  X-Robots-Tag: noindex, nofollow, noarchive

/flutter_service_worker.js
  Cache-Control: no-store, no-cache, must-revalidate

/flutter_bootstrap.js
  Cache-Control: no-cache

/assets/*
  Cache-Control: public, max-age=31536000, immutable
