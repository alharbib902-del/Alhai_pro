# Alhai Distributor Portal — environment variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env.
#
# Usage:
#   flutter run -d chrome --dart-define-from-file=.env
#   flutter build web --dart-define-from-file=.env

# required: Supabase project URL (https://<project>.supabase.co)
SUPABASE_URL=your-supabase-url-here

# required: Supabase anon (public) API key
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# required: build flavor (dev | staging | prod)
FLAVOR=dev

# optional: Sentry DSN for Distributor Portal error reporting (leave blank in dev)
SENTRY_DSN_DISTRIBUTOR=your-sentry-dsn-here
