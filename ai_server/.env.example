# Alhai AI Server — environment variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env.

# required: Supabase project URL (must start with https://; server refuses to start otherwise)
SUPABASE_URL=your-supabase-url-here

# required: Supabase anon (public) API key
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# required: Supabase service role key (server-side only; NEVER expose to clients)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# required: JWT signing secret, must be AT LEAST 32 characters long and match
# the secret in Supabase Dashboard -> Project Settings -> API -> JWT Secret.
# The server refuses to start if this is missing, empty, or too short.
JWT_SECRET=your-jwt-secret-at-least-32-characters-long-here

# required for AI report generation: OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# optional: bind address for the HTTP server (0.0.0.0 to listen on all interfaces)
HOST=0.0.0.0

# optional: HTTP server port
PORT=8000

# optional: enable debug logging and auto-reload (set to true ONLY for local dev)
DEBUG=false

# required: comma-separated list of CORS-allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# optional: Redis URL for OpenAI response cache. Leave empty to disable cache.
# Dev/CI: REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# optional: OpenAI cache TTL in seconds (default 86400 = 24 hours)
OPENAI_CACHE_TTL_SECONDS=86400
