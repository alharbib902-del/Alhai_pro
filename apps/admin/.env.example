# Alhai Admin — environment variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# required: Supabase project URL (https://<project>.supabase.co)
SUPABASE_URL=your-supabase-url-here

# required: Supabase anon (public) API key
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# required: build flavor (dev | staging | prod)
FLAVOR=dev

# optional: Sentry DSN for Admin error reporting (leave blank in dev)
SENTRY_DSN_ADMIN=your-sentry-dsn-here

# required for WhatsApp OTP/notifications: WaSender API token
WASENDER_API_TOKEN=your-wasender-api-token-here

# required for WhatsApp OTP/notifications: WaSender device identifier
WASENDER_DEVICE_ID=your-wasender-device-id-here

# required for WhatsApp OTP/notifications: sender phone in E.164 format
WASENDER_PHONE=your-wasender-phone-here

# required for WhatsApp OTP/notifications: display name shown in messages
WASENDER_NAME=your-store-name-here

# required for WhatsApp OTP/notifications: webhook signing secret
WASENDER_WEBHOOK_SECRET=your-wasender-webhook-secret-here

# optional: AI Server base URL (for AI-assisted features)
AI_SERVER_URL=your-ai-server-url-here

# Firebase (optional, for push notifications):
# Firebase is configured via google-services.json / GoogleService-Info.plist,
# not via dart-define. No env var needed here.
