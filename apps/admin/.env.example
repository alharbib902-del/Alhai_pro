# Alhai Admin — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# ── Supabase (required) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── App Flavor (dev | staging | prod) ────────────────────────
FLAVOR=dev

# ── Sentry (error reporting, optional in dev) ────────────────
SENTRY_DSN_ADMIN=https://your-sentry-dsn-here

# ── WaSender / WhatsApp (for OTP & notifications) ────────────
WASENDER_API_TOKEN=your-wasender-api-token
WASENDER_DEVICE_ID=your-device-id
WASENDER_PHONE=+966xxxxxxxxx
WASENDER_NAME=your-store-name
WASENDER_WEBHOOK_SECRET=your-webhook-secret

# ── AI Server (optional, for AI features) ────────────────────
AI_SERVER_URL=https://api.alhai.store

# ── Firebase (optional, for push notifications) ──────────────
# Firebase is configured via google-services.json / GoogleService-Info.plist,
# not via dart-define. No env var needed here.
