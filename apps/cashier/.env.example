# Alhai Cashier — environment variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# required: deployment environment (dev | staging | production)
# Note: other Flutter apps in this repo use FLAVOR for the same concept.
ENV=dev

# required: Supabase project URL (https://<project>.supabase.co)
SUPABASE_URL=your-supabase-url-here

# required: Supabase anon (public) API key
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# optional: Sentry DSN for error reporting (leave blank in dev)
SENTRY_DSN=your-sentry-dsn-here

# optional: Firebase Web API key for push notifications
# FIREBASE_API_KEY=your-firebase-api-key-here
