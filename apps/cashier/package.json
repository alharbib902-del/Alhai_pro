{
  "name": "alhai-cashier-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:login": "playwright test e2e/tests/login.spec.ts",
    "test:pos": "playwright test e2e/tests/pos.spec.ts",
    "test:nav": "playwright test e2e/tests/navigation.spec.ts",
    "test:critical": "playwright test --grep @critical",
    "test:high": "playwright test --grep @high",
    "test:medium": "playwright test --grep @medium",
    "test:priorities": "playwright test --grep \"@critical|@high|@medium\"",
    "test:cashier:all": "npm run test:critical && npm run test:high && npm run test:medium",
    "test:full-suite": "playwright test e2e/tests/full-suite.spec.ts",
    "test:full-suite:headed": "playwright test e2e/tests/full-suite.spec.ts --headed",
    "test:auth": "playwright test e2e/tests/full-suite.spec.ts --grep \"Authentication\"",
    "test:payment": "playwright test e2e/tests/full-suite.spec.ts --grep \"Payment\"",
    "test:shifts": "playwright test e2e/tests/full-suite.spec.ts --grep \"Shift\"",
    "test:customers": "playwright test e2e/tests/full-suite.spec.ts --grep \"Customer\"",
    "test:inventory": "playwright test e2e/tests/full-suite.spec.ts --grep \"Inventory\"",
    "test:responsive": "playwright test e2e/tests/full-suite.spec.ts --grep \"Responsive\"",
    "test:offline": "playwright test e2e/tests/full-suite.spec.ts --grep \"Offline\"",
    "test:performance": "playwright test e2e/tests/full-suite.spec.ts --grep \"Performance\"",
    "test:security": "playwright test e2e/tests/full-suite.spec.ts --grep \"Security\"",
    "test:all-e2e": "npm run test:cashier:all && npm run test:full-suite",
    "test:everything": "bash ./scripts/run-all-tests.sh --report",
    "test:quick": "bash ./scripts/run-all-tests.sh --quick",
    "test:full": "powershell -ExecutionPolicy Bypass -File ./scripts/run-cashier-full-suite.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
