# Alhai Driver App — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# ── Supabase (required) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── App Flavor (dev | staging | prod) ────────────────────────
FLAVOR=dev

# ── Sentry (error reporting, optional in dev) ────────────────
SENTRY_DSN_DRIVER=https://your-sentry-dsn-here

# ── Certificate Pinning (recommended for production) ─────────
# SHA-256 fingerprint of the Supabase TLS certificate.
# Get it with:
#   openssl s_client -connect your-project.supabase.co:443 | openssl x509 -fingerprint -sha256
SUPABASE_CERT_FINGERPRINT=your-sha256-fingerprint-here
SUPABASE_CERT_FINGERPRINT_BACKUP=your-backup-fingerprint-here

# ── Firebase (optional, for push notifications) ──────────────
# Firebase is configured via google-services.json / GoogleService-Info.plist,
# not via dart-define. No env var needed here.
