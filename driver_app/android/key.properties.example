# Copy this file to android/key.properties and fill in your release keystore details.
# android/key.properties is gitignored — never commit the real file.
#
# To generate a new keystore:
#   keytool -genkey -v -keystore ~/alhai-driver-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Then point storeFile at the generated .jks file (absolute path is fine).

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=/absolute/path/to/alhai-driver-upload.jks
