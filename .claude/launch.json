{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cashier",
      "runtimeExecutable": "C:\\src\\flutter\\bin\\flutter.bat",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "8080", "--dart-define-from-file=../../.dart_define.env"],
      "cwd": "apps/cashier",
