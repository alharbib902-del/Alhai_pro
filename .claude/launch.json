{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cashier",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "flutter", "run", "-d", "web-server", "--web-port", "8080"],
      "cwd": "apps/cashier",
      "autoPort": false,
      "port": 8080
    },
    {
      "name": "ai-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "ai_server",
      "port": 8000
    },
    {
      "name": "report",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npx", "http-server", ".", "-p", "3001", "-c-1"],
      "port": 3001
    }
  ]
}
