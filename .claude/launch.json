    {
      "name": "ai-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "ai_server",
      "port": 8000
    }
  ]
}
