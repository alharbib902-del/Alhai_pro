# Alhai Customer App — environment variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# required: Supabase project URL (https://<project>.supabase.co)
SUPABASE_URL=your-supabase-url-here

# required: Supabase anon (public) API key
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# required: build flavor (dev | staging | prod)
FLAVOR=dev

# optional: Sentry DSN for Customer App error reporting (leave blank in dev)
SENTRY_DSN_CUSTOMER=your-sentry-dsn-here

# optional: base64-encoded SHA-256 of the Supabase TLS cert (release builds only)
# See docs/certificate_pinning_rotation.md for how to obtain and rotate these.
SUPABASE_CERT_FINGERPRINT=your-supabase-cert-fingerprint-here

# optional: base64-encoded SHA-256 backup pin for rotation windows
SUPABASE_CERT_FINGERPRINT_BACKUP=your-backup-cert-fingerprint-here

# Google Maps (for store locator):
# Android: set GOOGLE_MAPS_API_KEY in android/local.properties
#   or pass -PGOOGLE_MAPS_API_KEY=xxx to gradle.
# iOS: set GOOGLE_MAPS_API_KEY in ios/Flutter/Maps.xcconfig
#   (see ios/Flutter/Maps.xcconfig.example).

# Firebase (optional, for push notifications):
# Firebase is configured via google-services.json / GoogleService-Info.plist,
# not via dart-define. No env var needed here.
