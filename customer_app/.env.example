# Alhai Customer App — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Usage:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# ── Supabase (required) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── App Flavor (dev | staging | prod) ────────────────────────
FLAVOR=dev

# ── Sentry (error reporting, optional in dev) ────────────────
SENTRY_DSN_CUSTOMER=https://your-sentry-dsn-here

# ── Google Maps (for store locator) ──────────────────────────
# Android: also set GOOGLE_MAPS_API_KEY in android/local.properties
#   or pass via -PGOOGLE_MAPS_API_KEY=xxx to gradle.
# iOS: set GOOGLE_MAPS_API_KEY in ios/Flutter/Maps.xcconfig
#   (see ios/Flutter/Maps.xcconfig.example).

# ── Firebase (optional, for push notifications) ──────────────
# Firebase is configured via google-services.json / GoogleService-Info.plist,
# not via dart-define. No env var needed here.
